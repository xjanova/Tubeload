<Window x:Class="TubeLoad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TubeLoad - Video Downloader"
        Height="780" Width="950" MinHeight="650" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Quality Item Button Style (transparent, no chrome) -->
        <Style x:Key="QualityItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#111827" Offset="0.5"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00B4D8" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#9654;" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="2,0,0,0"/>
                        </Border>
                        <TextBlock Text="TubeLoad" Foreground="#E6EDF3" FontSize="14" FontWeight="Bold"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="v1.0" Foreground="#4A5568" FontSize="10" Margin="8,2,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                        <!-- Debug Button (visible only in Debug builds) -->
                        <Button x:Name="DebugBtn" Click="DebugBtn_Click"
                                Height="26" Margin="0,0,8,0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"
                                Visibility="Collapsed" VerticalAlignment="Center">
                            <Border CornerRadius="6" Padding="10,3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF6B35" Offset="0"/>
                                        <GradientStop Color="#F7C948" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#128736;" FontSize="10" Margin="0,0,4,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="DEBUG" Foreground="#0A0E14" FontSize="9"
                                               FontWeight="ExtraBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button Content="&#x2500;" Click="MinimizeBtn_Click"
                                Width="36" Height="30" FontSize="12"
                                Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" VerticalContentAlignment="Center"/>
                        <Button x:Name="MaxBtn" Content="&#x25A1;" Click="MaximizeBtn_Click"
                                Width="36" Height="30" FontSize="12"
                                Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" VerticalContentAlignment="Center"/>
                        <Button Content="&#x2715;" Click="CloseBtn_Click"
                                Width="36" Height="30" FontSize="12"
                                Foreground="#8B949E" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="28,10,28,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,0,0,6">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00E5FF" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="0.5"/>
                                    <GradientStop Color="#EC4899" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            Video Downloader
                        </TextBlock>
                        <TextBlock Text="Download videos from YouTube and TikTok in any quality"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    </StackPanel>

                    <!-- URL Input -->
                    <Border Grid.Row="1" CornerRadius="16" Padding="24" Margin="0,0,0,20"
                            Effect="{StaticResource SubtleShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1C2333" Offset="0"/>
                                <GradientStop Color="#1A2236" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2D3748" Offset="0"/>
                                <GradientStop Color="#1E293B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <TextBox x:Name="UrlTextBox" Style="{StaticResource ModernTextBox}"
                                             TextChanged="UrlTextBox_TextChanged"
                                             KeyDown="UrlTextBox_KeyDown"/>
                                    <TextBlock x:Name="UrlPlaceholder"
                                               Text="Paste YouTube or TikTok URL here..."
                                               Foreground="#4A5568" FontSize="14"
                                               VerticalAlignment="Center" Margin="18,0,0,0"
                                               IsHitTestVisible="False"/>
                                </Grid>

                                <Button Grid.Column="1" Content="&#128203; Paste"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,0"
                                        Click="PasteBtn_Click"/>

                                <Button Grid.Column="2" x:Name="FetchBtn"
                                        Style="{StaticResource ModernButton}"
                                        Margin="8,0,0,0"
                                        Click="FetchBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#128269;" FontSize="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Fetch Info" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0"
                                        x:Name="PlatformBadge" Visibility="Collapsed">
                                <Border CornerRadius="8" Padding="10,5" Background="#1A2744">
                                    <TextBlock x:Name="PlatformText" Foreground="#00B4D8" FontSize="12" FontWeight="Medium"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Video Info Card -->
                    <Border Grid.Row="2" x:Name="VideoInfoCard" CornerRadius="16" Padding="24"
                            Margin="0,0,0,20" Visibility="Collapsed"
                            Effect="{StaticResource SubtleShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1C2333" Offset="0"/>
                                <GradientStop Color="#1A2236" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2D3748" Offset="0"/>
                                <GradientStop Color="#1E293B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Video Info Row -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="12" Width="200" Height="120"
                                        ClipToBounds="True" Margin="0,0,20,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2D3748" Offset="0"/>
                                            <GradientStop Color="#1E293B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Image x:Name="ThumbnailImage" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="VideoTitle" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" MaxHeight="48"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Border CornerRadius="6" Padding="8,4" Background="#1A2744" Margin="0,0,8,0">
                                            <TextBlock x:Name="UploaderText" Foreground="#00B4D8" FontSize="12"/>
                                        </Border>
                                        <Border CornerRadius="6" Padding="8,4" Background="#1A2744">
                                            <TextBlock x:Name="DurationText" Foreground="#A78BFA" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Quality Selection Header -->
                            <Grid Grid.Row="1" Margin="0,18,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#127916;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Select Quality" Foreground="#E6EDF3" FontSize="14"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" x:Name="FormatCountText" Foreground="#4A5568"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Quality Options List -->
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" MaxHeight="240" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="QualityList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="QualityItem_Click" Tag="{Binding}"
                                                        Style="{StaticResource QualityItemButton}"
                                                        Margin="0,0,0,6">
                                                    <Border x:Name="QualityBorder" CornerRadius="10" Padding="12,10"
                                                            Background="#0D1117" BorderThickness="1.5"
                                                            BorderBrush="#1E293B">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Icon -->
                                                            <Border CornerRadius="8" Width="34" Height="34"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#141B27" Offset="0"/>
                                                                        <GradientStop Color="#1A2236" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding Icon}" FontSize="16"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Quality Label + Tag -->
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding QualityLabel}" FontSize="13"
                                                                           FontWeight="SemiBold" Foreground="#E6EDF3"/>
                                                                <TextBlock Text="{Binding QualityTag}" FontSize="10"
                                                                           Foreground="#4A5568" Margin="0,2,0,0"/>
                                                            </StackPanel>

                                                            <!-- Format Badge -->
                                                            <Border Grid.Column="2" CornerRadius="6" Padding="8,3"
                                                                    Background="#1A2744" Margin="8,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FormatBadge}" Foreground="#00B4D8"
                                                                           FontSize="10" FontWeight="Bold"/>
                                                            </Border>

                                                            <!-- Type Badge (Video+Audio etc) -->
                                                            <Border Grid.Column="3" CornerRadius="6" Padding="8,3"
                                                                    Margin="6,0,0,0" VerticalAlignment="Center">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="#1A1A2E"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding TypeLabel}" Foreground="#A78BFA"
                                                                           FontSize="10" FontWeight="Medium"/>
                                                            </Border>

                                                            <!-- File Size -->
                                                            <TextBlock Grid.Column="4" Text="{Binding FileSize}"
                                                                       Foreground="#8B949E" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                                       MinWidth="60" TextAlignment="Right"/>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Selected Quality Summary + Download Button -->
                                <Border Grid.Row="1" CornerRadius="12" Padding="14,10" Margin="0,8,0,0"
                                        BorderThickness="1" BorderBrush="#2D3748">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#111827" Offset="0"/>
                                            <GradientStop Color="#0F172A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Selected indicator -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#9989;" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Selected:" Foreground="#4A5568" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="SelectedQualityText" Foreground="#00E5FF"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Download Button -->
                                        <Button Grid.Column="2" x:Name="DownloadBtn"
                                                Style="{StaticResource ModernButton}"
                                                Click="DownloadBtn_Click" Padding="20,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#11015;" FontSize="16" Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Download" FontSize="14" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Mini Video Info Bar (shown when VideoInfoCard is collapsed after download) -->
                    <Border Grid.Row="2" x:Name="VideoMiniBar" CornerRadius="12" Padding="14,10"
                            Margin="0,0,0,20" Visibility="Collapsed"
                            Background="#161B22" BorderThickness="1" BorderBrush="#2D3748">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail mini -->
                            <Border CornerRadius="8" Width="48" Height="32" ClipToBounds="True"
                                    Margin="0,0,10,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2D3748" Offset="0"/>
                                        <GradientStop Color="#1E293B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Image x:Name="MiniThumbnailImage" Stretch="UniformToFill"/>
                            </Border>

                            <!-- Title + quality badge -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock x:Name="MiniBarTitle" Foreground="#E6EDF3"
                                           FontSize="12" FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="MiniBarQuality" Foreground="#A78BFA"
                                           FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Download another quality button -->
                            <Button Grid.Column="2" Click="ExpandInfo_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,6" Margin="0,0,6,0"
                                    ToolTip="Change quality or download again">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#127916;" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Change Quality" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Close/dismiss button -->
                            <Button Grid.Column="3" Click="DismissInfo_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="6,4" ToolTip="Dismiss">
                                <TextBlock Text="✕" Foreground="#4A5568" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Output Directory & Cookie Browser -->
                    <Border Grid.Row="3" CornerRadius="12" Padding="16" Margin="0,0,0,20"
                            Background="#161B22" BorderThickness="1" BorderBrush="#2D3748">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#128193;" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" x:Name="OutputDirText"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2" Content="Open Folder"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OpenFolderBtn_Click" Margin="8,0,0,0"/>
                                <Button Grid.Column="3" Content="Browse"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BrowseBtn_Click" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Cookie Browser (for TikTok) -->
                            <Border Margin="0,12,0,0" CornerRadius="8" Padding="12,8"
                                    Background="#0D1117" BorderThickness="1" BorderBrush="#1E293B">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#127850;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="TikTok Cookie Browser:"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox Grid.Column="2" x:Name="CookieBrowserCombo"
                                              SelectionChanged="CookieBrowser_Changed"
                                              Background="#0D1117" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Padding="8,4" MinWidth="120"
                                              VerticalAlignment="Center"
                                              BorderThickness="1" BorderBrush="#2D3748"/>
                                    <TextBlock Grid.Column="3" x:Name="BrowserStatusText"
                                               Foreground="#00E676" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Tab Section: Downloads / History -->
                    <Border Grid.Row="4" CornerRadius="16" Padding="20" MinHeight="240"
                            Effect="{StaticResource SubtleShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1C2333" Offset="0"/>
                                <GradientStop Color="#1A2236" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2D3748" Offset="0"/>
                                <GradientStop Color="#1E293B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Button x:Name="TabDownloads" Content="Downloads"
                                        Click="TabDownloads_Click"
                                        Foreground="#E6EDF3" Background="Transparent"
                                        BorderThickness="0,0,0,2" Padding="14,8"
                                        FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                                    <Button.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00B4D8" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.BorderBrush>
                                </Button>
                                <Border x:Name="QueueCountBadge" CornerRadius="10" Padding="7,2"
                                        Margin="6,0,0,0" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00B4D8" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="QueueCountText" Foreground="White"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>

                                <Button x:Name="TabHistory" Content="History"
                                        Click="TabHistory_Click"
                                        Foreground="#4A5568" Background="Transparent"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                        Padding="14,8" Margin="10,0,0,0"
                                        FontSize="14" FontWeight="Medium" Cursor="Hand"/>
                                <Border x:Name="HistoryCountBadge" CornerRadius="10" Padding="7,2"
                                        Margin="6,0,0,0" VerticalAlignment="Center"
                                        Background="#2D3748" Visibility="Collapsed">
                                    <TextBlock x:Name="HistoryCountText" Foreground="#8B949E"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <!-- Downloads Panel -->
                            <Grid x:Name="DownloadsPanel" Grid.Row="1">
                                <StackPanel x:Name="EmptyState"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Margin="0,20,0,20">
                                    <TextBlock Text="&#127916;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="No downloads yet" Foreground="#4A5568"
                                               FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Paste a URL above to get started"
                                               Foreground="#374151" FontSize="12" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <ItemsControl x:Name="DownloadList" Visibility="Collapsed">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="14,12" Margin="0,0,0,10"
                                                    BorderThickness="1.5"
                                                    BorderBrush="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#161B22" Offset="0"/>
                                                        <GradientStop Color="#111827" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Title + Quality Badge + Status -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Status indicator dot -->
                                                        <Border Width="10" Height="10" CornerRadius="5"
                                                                Margin="0,0,10,0" VerticalAlignment="Center"
                                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13"
                                                                   FontWeight="Medium" Foreground="#E6EDF3"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Grid.Column="2" CornerRadius="6" Padding="8,3"
                                                                Background="#1A2744" Margin="10,0,0,0"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Quality}" Foreground="#A78BFA"
                                                                       FontSize="10" FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Progress Bar (always visible, shows state) -->
                                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                                        <Border CornerRadius="6" Height="14" Background="#0D1117"
                                                                x:Name="ProgressBarBg" ClipToBounds="True">
                                                            <Border CornerRadius="6" HorizontalAlignment="Left"
                                                                    MinWidth="2">
                                                                <Border.Width>
                                                                    <MultiBinding Converter="{StaticResource ProgressToWidth}">
                                                                        <Binding Path="Progress"/>
                                                                        <Binding Path="ActualWidth" ElementName="ProgressBarBg"/>
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                                                        <GradientStop Color="#7C3AED" Offset="0.5"/>
                                                                        <GradientStop Color="#EC4899" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                        </Border>
                                                        <!-- Percentage overlay -->
                                                        <TextBlock Text="{Binding ProgressText}" FontSize="9"
                                                                   Foreground="White" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>

                                                    <!-- Speed / ETA row -->
                                                    <Grid Grid.Row="2" Margin="0,6,0,0"
                                                          Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#9889;" FontSize="10" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding SpeedDisplay}" FontSize="11"
                                                                       Foreground="#00B4D8" FontWeight="Medium"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="&#9201;" FontSize="10" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding EtaDisplay}" FontSize="11"
                                                                       Foreground="#A78BFA" FontWeight="Medium"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Status Text -->
                                                    <TextBlock Grid.Row="3" Text="{Binding StatusText}"
                                                               FontSize="12" Margin="0,6,0,0" FontWeight="Medium"
                                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- History Panel -->
                            <Grid x:Name="HistoryPanel" Grid.Row="1" Visibility="Collapsed">
                                <!-- History Empty State -->
                                <StackPanel x:Name="HistoryEmpty"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Margin="0,20,0,20">
                                    <TextBlock Text="&#128214;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="No history yet" Foreground="#4A5568"
                                               FontSize="14" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Grid x:Name="HistoryContent" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Search + Clear buttons -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="HistorySearchBox" Style="{StaticResource ModernTextBox}"
                                                 FontSize="12" Padding="10,8"
                                                 TextChanged="HistorySearchBox_TextChanged"/>
                                        <Button Grid.Column="1" Content="Clear All"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="8,0,0,0" Foreground="#FF5252"
                                                Click="ClearHistoryBtn_Click"/>
                                    </Grid>

                                    <ItemsControl x:Name="HistoryList" Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="10" Margin="0,0,0,8"
                                                        Background="#161B22" BorderThickness="1" BorderBrush="#2D3748">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Thumbnail -->
                                                        <Border CornerRadius="8" Width="72" Height="48"
                                                                ClipToBounds="True" Margin="0,0,10,0"
                                                                VerticalAlignment="Center">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#2D3748" Offset="0"/>
                                                                    <GradientStop Color="#1E293B" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Grid>
                                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                                <!-- Status overlay -->
                                                                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                        CornerRadius="4" Padding="4,1" Margin="2"
                                                                        Background="#CC000000">
                                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="9"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Platform badge -->
                                                        <Border Grid.Column="1" CornerRadius="6" Padding="6,3"
                                                                Margin="0,0,10,0" VerticalAlignment="Center"
                                                                Height="22">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1A2744"/>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Platform}" Foreground="#00B4D8"
                                                                       FontSize="9" FontWeight="Bold"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Info -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                                       FontWeight="Medium" Foreground="#E6EDF3"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                <Border CornerRadius="4" Padding="5,1" Background="#1A1A2E"
                                                                        Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding Quality}" FontSize="9"
                                                                               Foreground="#A78BFA" FontWeight="Medium"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding DateDisplay}" FontSize="10"
                                                                           Foreground="#4A5568" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Re-download button -->
                                                        <Button Grid.Column="3" ToolTip="Re-download"
                                                                Background="Transparent" BorderThickness="0"
                                                                Cursor="Hand" Click="RedownloadBtn_Click"
                                                                Tag="{Binding Url}" VerticalAlignment="Center"
                                                                Margin="8,0,0,0">
                                                            <Border CornerRadius="8" Padding="10,6" Background="#1A2744">
                                                                <TextBlock Text="&#128260;" FontSize="13"
                                                                           Foreground="#8B949E"/>
                                                            </Border>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Status Bar -->
                    <Border Grid.Row="5" Margin="0,16,0,0" CornerRadius="10" Padding="14,10"
                            Background="#161B22" BorderThickness="1" BorderBrush="#2D3748">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Status Icon -->
                            <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4"
                                    Background="#00E676" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="StatusText" Text="Ready"
                                       Foreground="#8B949E" FontSize="12"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Foreground="#374151" FontSize="11"
                                       VerticalAlignment="Center">
                                <Run Text="Developed by"/>
                                <Run Text=" "/>
                                <Run Text="Xman Studio" Foreground="#4A5568" FontWeight="Medium"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2"
                    Background="#CC0D1117" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="#00B4D8" Background="#1C2333"
                                 BorderThickness="0"/>
                    <TextBlock x:Name="LoadingText" Text="Loading..." Foreground="#8B949E"
                               FontSize="14" Margin="0,16,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
